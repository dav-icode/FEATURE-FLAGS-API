# ────────────────────────────────────────────────────────────
# Feature Flags API — Environment Variables
# Copy this file to .env and fill in the values
# ────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_USER=ff_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=feature_flags
DATABASE_URL=postgresql://ff_user:change_me_in_production@localhost:5432/feature_flags

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# Cache TTL in seconds for flag evaluations (default: 30s)
# Lower = more real-time updates, higher = less DB/Redis load
CACHE_TTL_SECONDS=30

# API
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
